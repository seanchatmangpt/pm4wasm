# Server Configuration
NODE_ENV=development
PORT=3000
API_VERSION=v1

# JWT Secrets
JWT_ACCESS_SECRET=your-super-secret-access-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pm4wasm?schema=public"

# OAuth 2.0 - Google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/v1/auth/oauth/google/callback

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
STRIPE_PRICE_ID_PRO=price_your-pro-price-id
STRIPE_PRICE_ID_ENTERPRISE=price_your-enterprise-price-id

# Frontend URLs
FRONTEND_URL=http://localhost:5173
FRONTEND_SUCCESS_URL=http://localhost:5173/billing/success
FRONTEND_CANCEL_URL=http://localhost:5173/billing/cancel

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# WebSocket
WS_PORT=3001
WS_PATH=/socket.io/

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Redis (for session storage - optional, falls back to memory)
REDIS_URL=redis://localhost:6379
